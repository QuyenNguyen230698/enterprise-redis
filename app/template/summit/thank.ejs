                    width="140"
                    height="50"
                    style="width:140px;height:50px;outline:none;border:none;text-decoration:none;vertical-align:middle;display:inline-block;max-width:100%"
                  />
                </div>
                <div style="padding:16px 24px 40px 24px">
                  <div
                    style="font-size:14px;font-weight:normal;padding:0px 0px 0px 0px"
                  >
                    <p>Kính gửi <%-name%>,</p>
                  </div>
                  <div
                    style="font-size:12px;font-weight:normal;padding:0px 0px 8px 0px"
                  >
                    TRAN DUC CORPORATION trân trọng cảm ơn Quý đối tác tham dự
                    Netzero Summit 2024
                  </div>
                  <div
                    style="font-size:14px;font-weight:bold;padding:0px 0px 0px 0px"
                  >
                    <p style="font-size:14px;font-weight:normal;padding:0px 0px 0px 0px">Thông tin:</p>
                    <ul style="font-size:12px;font-weight:normal">
                      <li>Bài phát biểu của KABAYA</li>
                      <li>Bài phát biểu của Mr. Hiển</li>
                      <li>Bài phát biểu của Mr. Neil</li>
                      <li>Bài phát biểu của Mr. Andrea</li>
                      <li>Bài phát biểu của Mr. Peter</li>
                      <li>Bài phát biểu của Mr. Trung</li>
                    </ul>
                  </div>
                  <div style="padding:4px 0px 12px 0px">
