                      style="width:100%;border:none;border-top:1px solid #CCCCCC;margin:0"
                    />
                  </div>
                  <div
                    style="font-size:12px;font-weight:normal;padding:0px 0px 0px 0px"
                  >
                    Dear <%-name%>,
                  </div>
                  <div
                    style="font-size:12px;font-weight:normal;padding:8px 0px 8px 0px"
